#!/usr/bin/env python3
import argparse
import os
import random
import math
from PIL import Image
import mido
from mido import Message, MidiFile, MidiTrack

def get_scale():
    bass_scale = [36, 40, 43, 45, 48]          
    chord_scale = [48, 52, 55, 57, 60, 64, 67] 
    melody_scale = [60, 64, 67, 69, 72, 76, 79, 81, 84, 88, 91] 
    return bass_scale, chord_scale, melody_scale

def analyze_image_color_mood(img_rgb):
    small_img = img_rgb.resize((100, 100))
    paletted = small_img.convert('P', palette=Image.Palette.ADAPTIVE, colors=4)
    
    palette_colors = paletted.getcolors()
    rgb_palette = paletted.getpalette()
    
    dominant_rgb_colors = []
    if palette_colors and rgb_palette:
        for count, pixel_value in palette_colors:
            idx = pixel_value * 3
            r = rgb_palette[idx]
            g = rgb_palette[idx+1]
            b = rgb_palette[idx+2]
            dominant_rgb_colors.append((r, g, b, count))

    best_r, best_g, best_b = 127, 127, 127
    highest_vibrancy = -1
    
    for r, g, b, count in dominant_rgb_colors:
        if (r + g + b) < 60 or (r + g + b) > 700:
            continue
        vibrancy = max(r, g, b) - min(r, g, b)
        if vibrancy > highest_vibrancy:
            highest_vibrancy = vibrancy
            best_r, best_g, best_b = r, g, b

    print(f"🎨 Pure RGB Values Derived -> Red: {best_r}, Green: {best_g}, Blue: {best_b}")

    melody = int((best_r / 255.0) * 103)
    chord = int((best_g / 255.0) * 103)
    bass = 32 + int((best_b / 255.0) * 7)

    print(f"🎛️ Generative Mapping -> Melody Patch: #{melody} | Chord Patch: #{chord} | Bass Patch: #{bass}")
    return melody, chord, bass

def scale_velocity(raw_val, max_input, min_output, max_output):
    """Applies a smooth logarithmic curve to translate pixel edges into human velocities."""
    if raw_val <= 0:
        return min_output
    factor = math.log(raw_val) / math.log(max_input)
    return int(min_output + (max_output - min_output) * min(1.0, factor))

def image_to_midi(image_path, melody_patch, chord_patch, bass_patch, base_bpm, humanize=False):
    img_orig = Image.open(image_path).convert('RGB')
    
    if melody_patch is None or chord_patch is None or bass_patch is None:
        auto_m, auto_c, auto_b = analyze_image_color_mood(img_orig)
        melody_patch = melody_patch if melody_patch is not None else auto_m
        chord_patch = chord_patch if chord_patch is not None else auto_c
        bass_patch = bass_patch if bass_patch is not None else auto_b

    print(f"🎹 Instrument Loadout -> Melody: #{melody_patch} | Chords: #{chord_patch} | Bass: #{bass_patch}")

    img = img_orig.convert('L').resize((64, 30))
    width, height = img.size

    mid = MidiFile(type=1)
    
    music_track = MidiTrack()
    mid.tracks.append(music_track)
    
    drum_track = MidiTrack()
    mid.tracks.append(drum_track)
    
    for t in [music_track, drum_track]:
        t.append(mido.MetaMessage('set_tempo', tempo=mido.bpm2tempo(base_bpm)))
        
    music_track.append(Message('program_change', program=melody_patch, channel=0, time=0))
    music_track.append(Message('program_change', program=chord_patch, channel=1, time=0))
    music_track.append(Message('program_change', program=bass_patch, channel=2, time=0))
    drum_track.append(Message('program_change', program=0, channel=9, time=0)) 

    bass_scale, chord_scale, melody_scale = get_scale()
    GLOBAL_STEP_TICKS = 120

    # ----------------------------------------------------
    # 1. INTERLACED DRUM SCANNER
    # ----------------------------------------------------
    max_deltas = [0.0] * 16
    peak_deltas = [0.0] * 16
    brightness_profiles = [0.0] * 16

    for step in range(16):
        offsets = [step, step + 16, step + 32, step + 48]
        step_avg_deltas = []
        step_max_deltas = []
        step_brightness = []
        
        for x in offsets:
            x_next = x - 1 if x == width - 1 else x + 1
            slice_deltas = [abs(img.getpixel((x, y)) - img.getpixel((x_next, y))) for y in range(height)]
            step_avg_deltas.append(sum(slice_deltas) / len(slice_deltas))
            step_max_deltas.append(max(slice_deltas) if slice_deltas else 0)
            
            col_brightness = [img.getpixel((x, y)) for y in range(height)]
            step_brightness.append(sum(col_brightness) / len(col_brightness))
            
        max_deltas[step] = max(step_avg_deltas)
        peak_deltas[step] = max(step_max_deltas)
        brightness_profiles[step] = sum(step_brightness) / len(step_brightness)

    drum_loop = []
    for step in range(16):
        drum_step_notes = []
        curr_delta = max_deltas[step]
        curr_peak = peak_deltas[step]
        curr_bright = brightness_profiles[step]

        # Hi-Hats
        if step % 2 == 0:
            if curr_bright > 135:
                drum_step_notes.append((46, 80))  
            else:
                drum_step_notes.append((42, 75))  
        elif curr_delta > 25:
            drum_step_notes.append((42, scale_velocity(curr_delta, 255, 40, 75)))

        # Kicks
        if step == 0 or (curr_delta > 22 and step % 2 == 0):
            kick_vel = scale_velocity(curr_delta, 255, 70, 115)
            drum_step_notes.append((36, kick_vel))

        # Snares
        if curr_delta > 35 and step % 4 != 0:
            snare_vel = scale_velocity(curr_peak, 255, 70, 112)
            drum_step_notes.append((38, snare_vel))
        elif step % 8 == 4:
            snare_vel = scale_velocity(curr_bright, 255, 75, 105)
            drum_step_notes.append((38, snare_vel))
            
        drum_loop.append(drum_step_notes)

    # Populate Drum Track
    active_drums = []
    for x in range(width):
        loop_step = x % 16
        step_notes = drum_loop[loop_step]
        
        for old_pitch in active_drums:
            drum_track.append(Message('note_off', note=old_pitch, velocity=0, channel=9, time=0))
        active_drums.clear()
        
        for pitch, vel in step_notes:
            drum_track.append(Message('note_on', note=pitch, velocity=vel, channel=9, time=0))
            active_drums.append(pitch)
            
        drum_track.append(Message('note_off', note=0, velocity=0, channel=9, time=GLOBAL_STEP_TICKS))

    # ----------------------------------------------------
    # 2. INSTRUMENT PIPELINE (With Voice-Leading & Note Gating)
    # ----------------------------------------------------
    active_music_notes = []
    
    for x in range(width):
        step_notes = [] 
        x_next = x - 1 if x == width - 1 else x + 1

        slice_deltas = [abs(img.getpixel((x, y)) - img.getpixel((x_next, y))) for y in range(height)]
        avg_delta = sum(slice_deltas) / len(slice_deltas)

        # Dynamic Gating Engine: Flat image zones sustain notes; busy zones play staccato
        if avg_delta < 15:
            gate_duration = int(GLOBAL_STEP_TICKS * 0.95)  # Legato hold
        elif avg_delta > 40:
            gate_duration = int(GLOBAL_STEP_TICKS * 0.40)  # Sharp staccato pluck
        else:
            gate_duration = int(GLOBAL_STEP_TICKS * 0.75)  # Standard hold

        # Bass Zone
        if x % 4 == 0:
            bass_edges = []
            for y in range(20, 30):
                edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
                if edge_value > 20:
                    bass_edges.append((y, edge_value))
            if bass_edges:
                best_y, edge_strength = max(bass_edges, key=lambda item: item[1])
                idx = min(len(bass_scale) - 1, max(0, int(((29 - best_y) / 10) * len(bass_scale))))
                vel = scale_velocity(edge_strength, 255, 60, 105)
                step_notes.append((bass_scale[idx], vel, 2))

        # Chord Zone (Harmonic Cleansing Rule)
        if x % 2 == 0:
            chord_edges = []
            for y in range(10, 20):
                edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
                if edge_value > 22:
                    idx = min(len(chord_scale) - 1, max(0, int(((19 - y) / 10) * len(chord_scale))))
                    vel = scale_velocity(edge_value, 255, 45, 85)
                    chord_edges.append((chord_scale[idx], vel))
            
            # Filter and sort to ensure a clean voicing without adjacent note mud
            chord_edges = sorted(list(set(chord_edges)), key=lambda item: item[0])
            filtered_chords = []
            for note_data in chord_edges:
                if not filtered_chords or abs(note_data[0] - filtered_chords[-1][0]) >= 3:
                    filtered_chords.append(note_data)
                    
            for pitch, vel in filtered_chords[:2]: # Limit to 2 cleanly separated voices
                step_notes.append((pitch, vel, 1))

        # Melody Zone
        melody_edges = []
        for y in range(0, 10):
            edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
            if edge_value > 28: 
                melody_edges.append((y, edge_value))
        if melody_edges:
            best_y, edge_strength = max(melody_edges, key=lambda item: item[1])
            idx = min(len(melody_scale) - 1, max(0, int(((9 - best_y) / 10) * len(melody_scale))))
            vel = scale_velocity(edge_strength, 255, 60, 115)
            step_notes.append((melody_scale[idx], vel, 0))

        if humanize:
            processed = []
            for pitch, vel, ch in step_notes:
                vel = max(35, min(125, vel + random.randint(-10, 10)))
                processed.append((pitch, vel, ch))
            step_notes = processed

        # Cut off prior elements cleanly
        for old_pitch, old_ch in active_music_notes:
            music_track.append(Message('note_off', note=old_pitch, velocity=0, channel=old_ch, time=0))
        active_music_notes.clear()

        # Execute note triggers
        for pitch, vel, ch in step_notes:
            music_track.append(Message('note_on', note=pitch, velocity=vel, channel=ch, time=0))
            active_music_notes.append((pitch, ch))

        # Separate note off events based on calculated gate length to preserve rhythm structure
        music_track.append(Message('note_off', note=0, velocity=0, channel=0, time=gate_duration))
        
        for pitch, vel, ch in step_notes:
            music_track.append(Message('note_off', note=pitch, velocity=0, channel=ch, time=0))
            
        music_track.append(Message('note_off', note=0, velocity=0, channel=0, time=GLOBAL_STEP_TICKS - gate_duration))

    return mid

def main():
    parser = argparse.ArgumentParser(description="Image-Driven Drum Sequencer & Melody Synth.")
    parser.add_argument("image", help="Path to image file")
    parser.add_argument("--velocity", choices=["humanize", "default"], default="default")
    parser.add_argument("--output", help="Output <filename>")
    parser.add_argument("--tempo", type=int, default=120, help="Base baseline tempo (BPM)")
    
    parser.add_argument("--melody", type=int, default=None)
    parser.add_argument("--chord", type=int, default=None)
    parser.add_argument("--bass", type=int, default=None)

    args = parser.parse_args()
    is_humanized = (args.velocity == "humanize")
    
    midi_data = image_to_midi(
        args.image, 
        melody_patch=args.melody, 
        chord_patch=args.chord, 
        bass_patch=args.bass, 
        base_bpm=args.tempo,
        humanize=is_humanized
    )
    
    if args.output:
        midi_data.save(args.output)
        print(f"🎵 Arrangement saved to: {args.output}")
    else:
        output_name = os.path.splitext(args.image)[0] + '.mid'
        midi_data.save(output_name)
        print(f"🎵 Arrangement automatically saved to: {output_name}")
      
if __name__ == "__main__":
    main()
