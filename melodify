#!/usr/bin/env python3
import argparse
import random
from PIL import Image
import mido
from mido import Message, MidiFile, MidiTrack

def get_scale():
    # A Minor Pentatonic / C Major Pentatonic distributions
    bass_scale = [36, 40, 43, 45, 48]          
    chord_scale = [48, 52, 55, 57, 60, 64, 67] 
    melody_scale = [60, 64, 67, 69, 72, 76, 79, 81, 84, 88, 91] 
    return bass_scale, chord_scale, melody_scale

def image_to_midi(image_path, melody_patch, chord_patch, bass_patch, humanize=False):
    # Grayscale image processing with 64 progressive steps
    img_large = Image.open(image_path).convert('L')
    img = img_large.resize((64, 30)) 
    width, height = img.size

    mid = MidiFile()
    track = MidiTrack()
    mid.tracks.append(track)
    track.append(mido.MetaMessage('set_tempo', tempo=mido.bpm2tempo(120)))

    # --- INITIALIZE GENERAL MIDI INSTRUMENTS ---
    # Channel 0: Melody | Channel 1: Chords | Channel 2: Bass | Channel 9 (MIDI 10): Drums
    track.append(Message('program_change', program=melody_patch, channel=0, time=0))
    track.append(Message('program_change', program=chord_patch, channel=1, time=0))
    track.append(Message('program_change', program=bass_patch, channel=2, time=0))
    # Note: Channel 9 in code is the 10th channel, automatically routed to Drums by your soundfont.
    track.append(Message('program_change', program=0, channel=9, time=0)) 

    bass_scale, chord_scale, melody_scale = get_scale()
    active_notes = [] # Keep track of active note tuples: (pitch, channel)

    for x in range(width):
        step_notes = [] # Format: (pitch, velocity, channel)
        x_next = min(x + 1, width - 1)

        # ----------------------------------------------------
        # 1. PERCUSSION LAYER (Channel 9 / MIDI Channel 10)
        # ----------------------------------------------------
        # Drum MIDI Codes: 36=Bass Drum, 38=Snare, 42=Closed Hi-Hat, 46=Open Hi-Hat
        # We will build a dynamic drum groove driven by image contrast values
        
        # Calculate overall visual variation at this slice step
        col_brightness = [img.getpixel((x, y)) for y in range(height)]
        avg_brightness = sum(col_brightness) / len(col_brightness)

        # A steady Hi-Hat pattern that accents on bright columns
        hh_vel = 75 if avg_brightness < 127 else 95
        if x % 2 == 0:
            step_notes.append((42, hh_vel, 9)) # Closed Hi-Hat on 8th notes
        elif x % 4 == 3 and avg_brightness > 140:
            step_notes.append((46, 80, 9))  # Open Hi-Hat accent on bright variations

        # Steady Kick drum pattern (on the downbeats)
        if x % 4 == 0:
            step_notes.append((36, 100, 9)) # Kick Drum on every beat

        # Snare pattern (Backbeat on steps 4, 12, 20, 28, etc.)
        if x % 8 == 4:
            step_notes.append((38, 95, 9))  # Snare Drum on beats 2 and 4

        # ----------------------------------------------------
        # 2. BASS ZONE (Channel 2)
        # ----------------------------------------------------
        if x % 4 == 0:
            bass_edges = []
            for y in range(20, 30):
                edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
                if edge_value > 20:
                    bass_edges.append((y, edge_value))
            if bass_edges:
                best_y, edge_strength = max(bass_edges, key=lambda item: item[1])
                idx = int(((29 - best_y) / 10) * len(bass_scale))
                idx = min(len(bass_scale) - 1, max(0, idx))
                vel = min(110, int((edge_strength / 255) * 50) + 55)
                step_notes.append((bass_scale[idx], vel, 2))

        # ----------------------------------------------------
        # 3. CHORD ZONE (Channel 1)
        # ----------------------------------------------------
        if x % 2 == 0:
            chord_edges = []
            for y in range(10, 20):
                edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
                if edge_value > 25:
                    idx = int(((19 - y) / 10) * len(chord_scale))
                    idx = min(len(chord_scale) - 1, max(0, idx))
                    vel = min(85, int((edge_value / 255) * 40) + 45)
                    chord_edges.append((chord_scale[idx], vel))
            
            unique_chords = list(set(chord_edges))
            if len(unique_chords) > 2:
                unique_chords = random.sample(unique_chords, 2)
            for pitch, vel in unique_chords:
                step_notes.append((pitch, vel, 1))

        # ----------------------------------------------------
        # 4. MELODY ZONE (Channel 0)
        # ----------------------------------------------------
        melody_edges = []
        for y in range(0, 10):
            edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
            if edge_value > 30: 
                melody_edges.append((y, edge_value))
        if melody_edges:
            best_y, edge_strength = max(melody_edges, key=lambda item: item[1])
            idx = int(((9 - best_y) / 10) * len(melody_scale))
            idx = min(len(melody_scale) - 1, max(0, idx))
            vel = min(120, int((edge_strength / 255) * 60) + 55)
            step_notes.append((melody_scale[idx], vel, 0))

        # Humanize Pass
        if humanize:
            processed = []
            for pitch, vel, ch in step_notes:
                # Do not randomize drum piece layout, only their strike velocities
                vel += random.randint(-12, 12)
                vel = max(35, min(125, vel))
                processed.append((pitch, vel, ch))
            step_notes = processed

        # --- MIDI Execution Array Execution ---
        # Turn off past step sounds
        for old_pitch, old_ch in active_notes:
            track.append(Message('note_off', note=old_pitch, velocity=0, channel=old_ch, time=0))
        active_notes.clear()

        # Turn on current sounds
        for pitch, vel, ch in step_notes:
            track.append(Message('note_on', note=pitch, velocity=vel, channel=ch, time=0))
            active_notes.append((pitch, ch))

        # Increment layout timer step (120 ticks = 16th note step resolution)
        track.append(Message('note_off', note=0, velocity=0, channel=0, time=120))

    # Safety clean up sequence ring
    for old_pitch, old_ch in active_notes:
        track.append(Message('note_off', note=old_pitch, velocity=0, channel=old_ch, time=0))

    return mid

def main():
    parser = argparse.ArgumentParser(description="Full Soundfont Patch Mapping with Percussion Engine.")
    parser.add_argument("image", help="Path to image file")
    parser.add_argument("--velocity", choices=["humanize", "default"], default="default")
    parser.add_argument("--soundfont", help="Path to soundfont file")
    parser.add_argument("--output", help="Output filename", default="output.mid")
    
    # Custom patch override flags (Defaults to: Synth Lead, Organ, and Synth Bass)
    parser.add_argument("--melody", type=int, default=80, help="General MIDI Patch ID (0-127)")
    parser.add_argument("--chord", type=int, default=16, help="General MIDI Patch ID (0-127)")
    parser.add_argument("--bass", type=int, default=38, help="General MIDI Patch ID (0-127)")

    args = parser.parse_args()
    is_humanized = (args.velocity == "humanize")
    
    print(f"🥁 Synthesizing 4-piece percussion band file for {args.image}...")
    midi_data = image_to_midi(
        args.image, 
        melody_patch=args.melody, 
        chord_patch=args.chord, 
        bass_patch=args.bass, 
        humanize=is_humanized
    )
    midi_data.save(args.output)
    print(f"🎵 Full arrangement track saved successfully to: {args.output}")

if __name__ == "__main__":
    main()
