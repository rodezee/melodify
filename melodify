#!/usr/bin/env python3
import argparse
import random
from PIL import Image
import mido
from mido import Message, MidiFile, MidiTrack

def get_scale():
    bass_scale = [36, 40, 43, 45, 48]          
    chord_scale = [48, 52, 55, 57, 60, 64, 67] 
    melody_scale = [60, 64, 67, 69, 72, 76, 79, 81, 84, 88, 91] 
    return bass_scale, chord_scale, melody_scale

def analyze_image_color_mood(img_rgb):
    """
    Finds the most dominant, saturated colors in the image rather than a flat average,
    preventing colorful images with dark backgrounds from being flagged as monochrome.
    """
    # 1. Reduce image to its 4 most dominant adaptive colors
    small_img = img_rgb.resize((100, 100))
    paletted = small_img.convert('P', palette=Image.Palette.ADAPTIVE, colors=4)
    
    # Extract the RGB values of those 4 dominant colors
    palette_colors = paletted.getcolors()
    rgb_palette = paletted.getpalette()
    
    dominant_rgb_colors = []
    if palette_colors and rgb_palette:
        for count, pixel_value in palette_colors:
            idx = pixel_value * 3
            r = rgb_palette[idx]
            g = rgb_palette[idx+1]
            b = rgb_palette[idx+2]
            dominant_rgb_colors.append((r, g, b, count))

    # 2. Analyze which of these dominant colors has the highest vibrant bias
    best_r, best_g, best_b = 127, 127, 127
    highest_vibrancy = -1
    
    for r, g, b, count in dominant_rgb_colors:
        # Avoid counting near-black or near-white background blocks as the vibrant "mood"
        if (r + g + b) < 60 or (r + g + b) > 700:
            continue
            
        # Vibrancy is defined by how much one channel stands out from the others
        vibrancy = max(r, g, b) - min(r, g, b)
        if vibrancy > highest_vibrancy:
            highest_vibrancy = vibrancy
            best_r, best_g, best_b = r, g, b

    print(f"🎨 Vibrant Color Detected -> Red: {best_r}, Green: {best_g}, Blue: {best_b} (Vibrancy: {highest_vibrancy})")

    # Default baseline
    melody, chord, bass = 80, 16, 33  # Square Lead, Organ, Finger Bass

    # Lower the threshold. If vibrancy is less than 35, it's truly a muted/monochrome picture
    if highest_vibrancy < 35:
        print("🎛️ Mood Detected: Muted/Monochromatic -> Choosing Acoustic Piano & Organ Profile.")
        melody, chord, bass = 0, 16, 32  # Acoustic Piano, Organ, Acoustic Bass
    elif max(best_r, best_g, best_b) == best_r:
        print("🔥 Mood Detected: Dominant Warmth/Red -> Choosing Bright Brass & Synth Lead Profile.")
        melody, chord, bass = 62, 81, 38  # Synth Brass 2, Saw Lead, Synth Bass 1
    elif max(best_r, best_g, best_b) == best_g:
        print("🌿 Mood Detected: Dominant Nature/Green/Yellow -> Choosing Woodwind & Nylon Guitar Profile.")
        melody, chord, bass = 73, 24, 33  # Flute, Acoustic Nylon Guitar, Finger Bass
    elif max(best_r, best_g, best_b) == best_b:
        print("❄️ Mood Detected: Dominant Cool/Blue -> Choosing Chilled Space & Synth Pad Profile.")
        melody, chord, bass = 81, 89, 39  # Saw Lead, Warm Pad, Synth Bass 2

    return melody, chord, bass

def image_to_midi(image_path, melody_patch, chord_patch, bass_patch, humanize=False):
    # Load original image in RGB mode to analyze color arrays
    img_orig = Image.open(image_path).convert('RGB')
    
    # 1. Determine Instruments via Color if they aren't explicitly forced
    if melody_patch is None or chord_patch is None or bass_patch is None:
        auto_m, auto_c, auto_b = analyze_image_color_mood(img_orig)
        melody_patch = melody_patch if melody_patch is not None else auto_m
        chord_patch = chord_patch if chord_patch is not None else auto_c
        bass_patch = bass_patch if bass_patch is not None else auto_b

    print(f"🎹 Instrument Loadout -> Melody: #{melody_patch} | Chords: #{chord_patch} | Bass: #{bass_patch}")

    # Now drop down sample grid for the notes via grayscale conversion
    img = img_orig.convert('L').resize((64, 30))
    width, height = img.size

    mid = MidiFile()
    track = MidiTrack()
    mid.tracks.append(track)
    track.append(mido.MetaMessage('set_tempo', tempo=mido.bpm2tempo(120)))

    # Set patches inside selected midi channels
    track.append(Message('program_change', program=melody_patch, channel=0, time=0))
    track.append(Message('program_change', program=chord_patch, channel=1, time=0))
    track.append(Message('program_change', program=bass_patch, channel=2, time=0))
    track.append(Message('program_change', program=0, channel=9, time=0)) # Drum kit channel

    bass_scale, chord_scale, melody_scale = get_scale()
    active_notes = []

    for x in range(width):
        step_notes = [] 
        x_next = min(x + 1, width - 1)

        # DRUM SEQUENCER ENGINE
        col_brightness = [img.getpixel((x, y)) for y in range(height)]
        avg_brightness = sum(col_brightness) / len(col_brightness)

        hh_vel = 75 if avg_brightness < 127 else 95
        if x % 2 == 0:
            step_notes.append((42, hh_vel, 9)) 
        elif x % 4 == 3 and avg_brightness > 140:
            step_notes.append((46, 80, 9))  

        if x % 4 == 0:
            step_notes.append((36, 100, 9)) 
        if x % 8 == 4:
            step_notes.append((38, 95, 9))  

        # BASS ZONE EDGE SAMPLER
        if x % 4 == 0:
            bass_edges = []
            for y in range(20, 30):
                edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
                if edge_value > 20:
                    bass_edges.append((y, edge_value))
            if bass_edges:
                best_y, edge_strength = max(bass_edges, key=lambda item: item[1])
                idx = int(((29 - best_y) / 10) * len(bass_scale))
                idx = min(len(bass_scale) - 1, max(0, idx))
                vel = min(110, int((edge_strength / 255) * 50) + 55)
                step_notes.append((bass_scale[idx], vel, 2))

        # CHORD ZONE EDGE SAMPLER
        if x % 2 == 0:
            chord_edges = []
            for y in range(10, 20):
                edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
                if edge_value > 25:
                    idx = int(((19 - y) / 10) * len(chord_scale))
                    idx = min(len(chord_scale) - 1, max(0, idx))
                    vel = min(85, int((edge_value / 255) * 40) + 45)
                    chord_edges.append((chord_scale[idx], vel))
            
            unique_chords = list(set(chord_edges))
            if len(unique_chords) > 2:
                unique_chords = random.sample(unique_chords, 2)
            for pitch, vel in unique_chords:
                step_notes.append((pitch, vel, 1))

        # MELODY ZONE EDGE SAMPLER
        melody_edges = []
        for y in range(0, 10):
            edge_value = abs(img.getpixel((x, y)) - img.getpixel((x_next, y)))
            if edge_value > 30: 
                melody_edges.append((y, edge_value))
        if melody_edges:
            best_y, edge_strength = max(melody_edges, key=lambda item: item[1])
            idx = int(((9 - best_y) / 10) * len(melody_scale))
            idx = min(len(melody_scale) - 1, max(0, idx))
            vel = min(120, int((edge_strength / 255) * 60) + 55)
            step_notes.append((melody_scale[idx], vel, 0))

        # Humanize
        if humanize:
            processed = []
            for pitch, vel, ch in step_notes:
                vel += random.randint(-12, 12)
                vel = max(35, min(125, vel))
                processed.append((pitch, vel, ch))
            step_notes = processed

        # Execute note conversions
        for old_pitch, old_ch in active_notes:
            track.append(Message('note_off', note=old_pitch, velocity=0, channel=old_ch, time=0))
        active_notes.clear()

        for pitch, vel, ch in step_notes:
            track.append(Message('note_on', note=pitch, velocity=vel, channel=ch, time=0))
            active_notes.append((pitch, ch))

        track.append(Message('note_off', note=0, velocity=0, channel=0, time=120))

    for old_pitch, old_ch in active_notes:
        track.append(Message('note_off', note=old_pitch, velocity=0, channel=old_ch, time=0))

    return mid

def main():
    parser = argparse.ArgumentParser(description="Color-Sensing Image-to-MIDI Converter.")
    parser.add_argument("image", help="Path to image file")
    parser.add_argument("--velocity", choices=["humanize", "default"], default="default")
    parser.add_argument("--soundfont", help="Path to soundfont file")
    parser.add_argument("--output", help="Output filename", default="output.mid")
    
    # Defaults changed to None so we can identify when to run the Auto-Color mood check
    parser.add_argument("--melody", type=int, default=None)
    parser.add_argument("--chord", type=int, default=None)
    parser.add_argument("--bass", type=int, default=None)

    args = parser.parse_args()
    is_humanized = (args.velocity == "humanize")
    
    midi_data = image_to_midi(
        args.image, 
        melody_patch=args.melody, 
        chord_patch=args.chord, 
        bass_patch=args.bass, 
        humanize=is_humanized
    )
    midi_data.save(args.output)
    print(f"🎵 Synthesized track written to: {args.output}")

if __name__ == "__main__":
    main()
